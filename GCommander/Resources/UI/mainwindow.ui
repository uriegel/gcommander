<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.3 -->
<interface>
  <!-- interface-name window.ui -->
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.20"/>
  <requires lib="libadwaita" version="1.7"/>
  <object class="AdwApplicationWindow" id="window">
    <property name="content">
      <object class="AdwToolbarView">
        <property name="content">
          <object class="GtkBox" id="box">
            <property name="hexpand">True</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkBox" id="folderpaned"/>
            </child>
            <child>
              <object class="GtkActionBar" id="actionBar">
                <property name="valign">end</property>
                <property name="vexpand">False</property>
                <child>
                  <object class="GtkBox">
                    <child>
                      <object class="GtkLabel" id="statusText">
                        <property name="ellipsize">end</property>
                        <property name="hexpand">False</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="selectedItemsText">
                        <property name="ellipsize">end</property>
                        <property name="hexpand">False</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="restrictionText">
                        <property name="ellipsize">end</property>
                        <property name="hexpand">False</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="backgroundActionText">
                        <property name="ellipsize">end</property>
                        <property name="hexpand">False</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="hexpand">True</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="labelDirs">
                        <property name="hexpand">False</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="hexpand">False</property>
                        <property name="label"> Verz.</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="labelFiles">
                        <property name="hexpand">False</property>
                        <property name="margin-start">5</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="hexpand">False</property>
                        <property name="label"> Dateien</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
        <child type="top">
          <object class="AdwHeaderBar" id="headerBar"/>
        </child>
      </object>
    </property>
    <property name="default-height">800</property>
    <property name="default-width">900</property>
    <property name="title">Commander</property>
  </object>
</interface>
