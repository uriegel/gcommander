<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.3 -->
<interface>
  <!-- interface-name window.ui -->
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.20"/>
  <requires lib="libadwaita" version="1.7"/>
  <object class="GtkPaned" id="folderpaned">
    <property name="end-child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkEditableLabel" id="pathRight"/>
        </child>
        <child>
          <object class="GtkScrolledWindow">
            <property name="hexpand">True</property>
            <property name="hscrollbar-policy">never</property>
            <child>
              <object class="GtkColumnView" id="columnviewRight">
                <property name="enable-rubberband">True</property>
                <property name="hexpand">True</property>
                <property name="tab-behavior">item</property>
                <property name="vexpand">True</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="hexpand">True</property>
    <property name="start-child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkEditableLabel" id="pathLeft"/>
        </child>
        <child>
          <object class="GtkScrolledWindow">
            <property name="hexpand">True</property>
            <property name="hscrollbar-policy">never</property>
            <child>
              <object class="GtkColumnView" id="columnviewLeft">
                <property name="enable-rubberband">True</property>
                <property name="hexpand">True</property>
                <property name="tab-behavior">item</property>
                <property name="vexpand">True</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="vexpand">True</property>
  </object>
</interface>
